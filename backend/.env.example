PANTHEON_DB_PATH=./data/pantheon.db
# Use 0.0.0.0 to allow LAN devices to access this CrowPilot instance.
PANTHEON_HOST=127.0.0.1
PANTHEON_PORT=8787

# Copilot Proxy or any OpenAI-compatible endpoint
PANTHEON_DEFAULT_PROVIDER=copilot_proxy
PANTHEON_COPILOT_BASE_URL=http://127.0.0.1:8080/v1
PANTHEON_COPILOT_MODEL=gpt-4.1
PANTHEON_COPILOT_API_KEY=

# Optional OpenAI-compatible local server (LiteLLM, vLLM, LM Studio, llama.cpp server, etc.)
# Leave empty to disable.
PANTHEON_LOCAL_BASE_URL=http://127.0.0.1:8082/v1
PANTHEON_LOCAL_MODEL=Qwen_Qwen3-14B-Q4_K_M.gguf
PANTHEON_LOCAL_API_KEY=

# ── Security Gate ──────────────────────────────────────────────────────────────
# Stage 2: General secrets/credentials scanner.
# Best choice: OpenPipe/PII-Redact-General (Llama 3.2 1B fine-tune, Pi-compatible).
#   F1≈1.00 for passwords/API keys, 99.8% IP recall, 100% SSN recall, 128k ctx.
#   Download GGUF: https://huggingface.co/OpenPipe/PII-Redact-General
#   Serve:  llama-server -m PII-Redact-General-Q8_0.gguf --port 8083 -c 8192
# Falls back to PANTHEON_LOCAL_* if left blank (uses your chat model as scanner).
PANTHEON_SCAN_BASE_URL=http://127.0.0.1:8083/v1
PANTHEON_SCAN_MODEL=PII-Redact-General-Q8_0.gguf
PANTHEON_SCAN_API_KEY=

# Optional MCP relay bearer token. If set, POST /mcp requires:
#   Authorization: Bearer <token>
# The stdio bridge reads this automatically from the environment.
PANTHEON_MCP_TOKEN=

# ── Embedding ──────────────────────────────────────────────────────────────────
# Local embedding model (used for knowledge base semantic search)
PANTHEON_EMBEDDING_BASE_URL=http://127.0.0.1:8081/v1
PANTHEON_EMBEDDING_MODEL=Qwen3-Embedding-0.6B-Q8_0.gguf

# Chunking defaults
PANTHEON_CHUNK_SIZE=700
PANTHEON_CHUNK_OVERLAP=120

# Optional: provide your own Fernet key for credential vault encryption.
# If omitted, CrowPilot creates backend/data/credential_vault.key locally.
PANTHEON_CREDENTIAL_KEY=

# Project workspace + Copilot CLI execution
PANTHEON_PROJECTS_ROOT=./projects
PANTHEON_COPILOT_CLI_COMMAND=gh
